MONGODB_URL=mongodb://mongo:27017
MONGODB_DB_NAME=price_tracking
SECRET_KEY=changeme_use_a_strong_random_secret_key_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CoinGecko Demo API — optional but recommended for stable 30 req/min rate limit
# Without a key the limit is dynamic (5–15 req/min depending on server load)
# Get a free Demo key at coingecko.com/en/api
# COINGECKO_API_KEY=your_coingecko_demo_key_here

# Finnhub Stock API — reference only, not exposed in public API (ToS restriction)
# FINNHUB_API_KEY=your_finnhub_api_key_here
